# MedCrux environment variables
# ─────────────────────────────────────────────────────────────────────
# ALL values below are OPTIONAL. The app runs fully without any of them
# (data is stored in the browser via localStorage, login is optional).
# Copy this file to .env.local and fill in only what you need.

# ── AI Tutor (optional) ──────────────────────────────────────────────
# Add a key to enable full Claude-powered tutor answers. Without it, the
# AI Tutor still works offline from the local drug library.
ANTHROPIC_API_KEY=

# ── Supabase Auth (optional — Phase 2) ───────────────────────────────
# Public keys — safe to expose in the client bundle. If unset, the app
# still builds/runs and login UI shows "Cloud login not configured yet".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Never prefix with NEXT_PUBLIC_ and never import into a
# client component. Used only by future server-only admin APIs
# (account delete/export). Leave blank for now.
SUPABASE_SERVICE_ROLE_KEY=

# Feature flag for cloud sync (Phase 2 sync engine). Keep "false" for now —
# auth foundation can exist while cloud sync stays disabled.
NEXT_PUBLIC_CLOUD_SYNC_ENABLED=false
