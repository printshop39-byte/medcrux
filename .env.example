# PharmaOS environment variables
# ─────────────────────────────────────────────────────────────────────
# ALL values below are OPTIONAL. The app runs fully without any of them
# (data is stored in the browser via localStorage). Copy this file to
# .env.local and fill in only what you need.

# ── AI Tutor (optional) ──────────────────────────────────────────────
# Add a key to enable full Claude-powered tutor answers. Without it, the
# AI Tutor still works offline from the local drug library.
ANTHROPIC_API_KEY=

# ── Supabase (OPTIONAL — NOT required for the current version) ────────
# The current release needs no database. These are placeholders for a
# future login / cloud-sync integration. Leave blank to run as-is.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
